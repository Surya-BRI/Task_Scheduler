NODE_ENV=development
PORT=7000
API_PREFIX=api/v1

# ─── Database ────────────────────────────────────────────────────────────────
# Prisma and the API both read DATABASE_URL. Alternatively set individual parts.
DATABASE_URL="sqlserver://localhost:1433;database=task_scheduler;user=sa;password=YourStrong@Passw0rd;encrypt=true;trustServerCertificate=true"
# DB_SERVER=localhost
# DB_PORT=1433
# DB_NAME=task_scheduler
# DB_USER=sa
# DB_PASSWORD=YourStrong@Passw0rd
# DB_ENCRYPT=true
# DB_TRUST_SERVER_CERTIFICATE=true

# ─── Internal JWT (AUTH_MODE=demo) ───────────────────────────────────────────
# Used when AUTH_MODE=demo (default for development/testing).
# Demo users are seeded by: npm run prisma:seed
# Demo credentials:
#   sarah.mitchell@bluerhine.com / hod123    (role: HOD)
#   alex.johnson@bluerhine.com   / alex123   (role: DESIGNER)
#   alexander.allen@bluerhine.com/ alex123   (role: DESIGNER)
#   benjamin.harris@bluerhine.com/ ben123    (role: DESIGNER)
JWT_ACCESS_SECRET=replace_with_strong_secret_min_16_chars
JWT_ACCESS_EXPIRES_IN=1d

# ─── Authentication Mode ─────────────────────────────────────────────────────
# AUTH_MODE=demo      (default) — validates tokens signed by JWT_ACCESS_SECRET above.
# AUTH_MODE=external            — validates tokens from the pre-existing ERP website.
AUTH_MODE=demo

# ─── External ERP Site Auth (AUTH_MODE=external) ─────────────────────────────
# Uncomment and configure these when connecting to the production ERP auth system.
#
# The JWT secret used by the external ERP website to sign tokens:
# EXTERNAL_JWT_SECRET=<copy_from_erp_site_config>
#
# Which JWT claim holds the user id? (default: sub)
# EXTERNAL_SUB_FIELD=sub
#
# Which JWT claim holds the email? (default: email)
# EXTERNAL_EMAIL_FIELD=email
#
# Which JWT claim holds the role? (default: role)
# EXTERNAL_ROLE_FIELD=role
#
# Map ERP site role labels → internal UserRole values (JSON object).
# Example: ERP uses "Hod", "Designer" — we use "HOD", "DESIGNER"
# EXTERNAL_ROLE_MAP={"Hod":"HOD","Designer":"DESIGNER","ProjectManager":"PROJECT_MANAGER","SalesPerson":"SALESPERSON","Admin":"ADMIN"}

# ─── Dev Bypass Headers (NODE_ENV=development only) ──────────────────────────
# In development, if no Authorization header is sent, the API accepts:
#   X-Dev-User-Id: <any-uuid>
#   X-Dev-User-Email: <email>
#   X-Dev-User-Role: HOD | DESIGNER | PROJECT_MANAGER | SALESPERSON | ADMIN
# This allows Postman / frontend testing without a real JWT.
# These headers are completely ignored in production.

# ─── CORS ────────────────────────────────────────────────────────────────────
CORS_ORIGIN=http://localhost:3000,http://localhost:5000
LOG_LEVEL=debug

# ─── ERP Raw Table Config ────────────────────────────────────────────────────
# Chatter posts — default table: [dbo].[ErpTSChatterPost]
# Optional: dbo table name only (if different from ErpTSChatterPost):
# ERP_CHATTER_POST_TABLE=TSChatterPost
# Optional: fully qualified table (other database / exact spelling). Overrides the above.
# ERP_CHATTER_POST_SQL_OBJECT=[SomeDb].[dbo].[TSChatterPost]
# Optional: cross-database catalog prefix for all ERP raw tables:
# ERP_SQL_CATALOG=MyErpDatabase
