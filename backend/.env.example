# Copy to backend/.env and fill in values.

NODE_ENV=development
PORT=7000
API_PREFIX=api/v1

# Required — minimum 16 characters
JWT_ACCESS_SECRET=change-me-min-16-chars
JWT_ACCESS_EXPIRES_IN=1d

# Required — comma-separated allowed browser origins
CORS_ORIGIN=http://localhost:5000

# Database — provide DATABASE_URL or DB_* parts
DATABASE_URL=
# DB_SERVER=localhost
# DB_PORT=1433
# DB_NAME=TaskScheduler
# DB_USER=sa
# DB_PASSWORD=
# DB_ENCRYPT=true
# DB_TRUST_SERVER_CERTIFICATE=true

# Logging / observability (optional)
LOG_LEVEL=debug
SERVICE_NAME=task-scheduler-api
SENTRY_DSN=
SENTRY_TRACES_SAMPLE_RATE=0.1
OTEL_EXPORTER_OTLP_ENDPOINT=

# Reliability (optional)
HTTP_REQUEST_TIMEOUT_MS=30000
SHUTDOWN_TIMEOUT_MS=15000

# AWS S3 uploads (optional)
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_REGION=ap-south-1
# AWS_BUCKET=
# AWS_FOLDER=taskfiles

# Production only — disable runtime DDL
# RUNTIME_SCHEMA_BOOTSTRAP=false
