NODE_ENV=development
PORT=7000
API_PREFIX=api/v1

# Prisma and the API both read DATABASE_URL. Alternatively set DB_SERVER, DB_PORT,
# DB_NAME, DB_USER, DB_PASSWORD, DB_ENCRYPT, and DB_TRUST_SERVER_CERTIFICATE.
DATABASE_URL="sqlserver://localhost:1433;database=task_scheduler;user=sa;password=YourStrong@Passw0rd;encrypt=true;trustServerCertificate=true"

JWT_ACCESS_SECRET=replace_with_strong_secret
JWT_ACCESS_EXPIRES_IN=1d
CORS_ORIGIN=http://localhost:5000
LOG_LEVEL=debug
