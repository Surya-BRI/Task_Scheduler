NODE_ENV=development
PORT=4000
API_PREFIX=api/v1

# Option A (recommended for readability): separate DB values
DB_SERVER=localhost
DB_PORT=1433
DB_NAME=task_scheduler
DB_USER=sa
DB_PASSWORD=YourStrong@Passw0rd
DB_ENCRYPT=true
DB_TRUST_SERVER_CERTIFICATE=true

# Option B (required by Prisma CLI commands): full DB URL
DATABASE_URL="sqlserver://localhost:1433;database=task_scheduler;user=sa;password=YourStrong@Passw0rd;encrypt=true;trustServerCertificate=true"

JWT_ACCESS_SECRET=replace_with_strong_secret
JWT_ACCESS_EXPIRES_IN=1d
CORS_ORIGIN=http://localhost:5000
LOG_LEVEL=debug
