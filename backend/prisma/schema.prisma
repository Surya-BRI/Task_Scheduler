generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlserver"
  url      = env("DATABASE_URL")
}

// ---------------------------------------------------------
// USERS & ROLES
// ---------------------------------------------------------
model Role {
  id          String   @id @default(dbgenerated("newid()")) @db.UniqueIdentifier
  name        String   @unique @db.NVarChar(50)
  permissions String?  @db.NVarChar(Max)
  users       User[]
  createdAt   DateTime @default(dbgenerated("sysutcdatetime()"))
  updatedAt   DateTime @default(dbgenerated("sysutcdatetime()")) @updatedAt

  @@map("ErpTSRole")
}

/// Legacy department table (referenced by ErpTSUser.departmentId).
model Department {
  id        String   @id @db.NVarChar(450)
  name      String   @unique
  users     User[]
  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt

  @@map("Department")
}

model User {
  id           String   @id @default(dbgenerated("newid()")) @db.UniqueIdentifier
  email        String   @unique @db.NVarChar(255)
  passwordHash String   @db.NVarChar(255)
  fullName     String   @db.NVarChar(150)
  roleId       String   @db.UniqueIdentifier
  departmentId String?  @db.NVarChar(450)

  role         Role     @relation(fields: [roleId], references: [id], onUpdate: NoAction)
  department   Department? @relation(fields: [departmentId], references: [id], onDelete: NoAction, onUpdate: NoAction)

  tasks                    Task[]                     @relation("TaskAssignee")
  projects                 Project[]                  @relation("ProjectCreator")
  projectAttachments       ProjectAttachment[]
  chatterPosts             ChatterPost[]              @relation("PostAuthor")
  chatterMentions          ChatterPost[]              @relation("MentionedUser")
  chatterComments          ChatterComment[]           @relation("CommentAuthor")
  chatterCommentMentions   ChatterComment[]           @relation("CommentMentionedUser")
  chatterPostMentions      ChatterPostMention[]       @relation("ChatterPostMentions")
  chatterCommentMentionEntries ChatterCommentMention[] @relation("ChatterCommentMentions")
  chatterPostLikes         ChatterPostLike[]          @relation("ChatterPostLikes")
  chatterPostSeen          ChatterPostSeen[]          @relation("ChatterPostSeen")
  projectQsAssignments     ProjectQsAssignment[]      @relation("ProjectQsAssignments")
  projectQsStatusesUpdated ProjectQsStatus[]          @relation("ProjectQsStatusUpdatedBy")
  projectQsStatusesSubmitted ProjectQsStatus[]        @relation("ProjectQsStatusSubmittedBy")
  activities               ActivityLog[]
  leaveRequests            LeaveRequest[]
  leaveRequestsApproved    LeaveRequest[]             @relation("LeaveApprover")
  leaveRequestsRevoked     LeaveRequest[]             @relation("LeaveRevoker")
  notifications            Notification[]
  inboxReadMarkers         InboxReadMarker[]          @relation("InboxReadMarkers")
  regularizationAsDesigner RegularizationRequest[]    @relation("RegularizationDesigner")
  regularizationAsApprover RegularizationRequest[]    @relation("RegularizationApprover")
  overtimeRequests         OvertimeRequest[]          @relation("OvertimeDesigner")
  schedulerAssignments     SchedulerAssignment[]      @relation("SchedulerDesigner")
  schedulerAssignedBy      SchedulerAssignment[]      @relation("SchedulerAssignedBy")
  schedulerWeeksUpdated    SchedulerWeek[]            @relation("SchedulerWeekUpdatedBy")
  schedulerAssignmentHistory SchedulerAssignmentHistory[] @relation("SchedulerAssignmentHistoryChangedBy")
  designTasksAssigned      DesignTask[]               @relation("DesignTaskAssignee")
  designTasksUpdated       DesignTask[]               @relation("DesignTaskUpdatedBy")
  conversations            ConversationParticipant[]
  messages                 Message[]                  @relation("MessageSender")
  workSessions             TaskWorkSession[]          @relation("WorkSessionDesigner")
  taskDesignerEntries      TaskDesigner[]             @relation("TaskDesignerUsers")
  overtimeApproved         OvertimeRequest[]          @relation("OvertimeApprovedBy")
  overtimeRejected         OvertimeRequest[]          @relation("OvertimeRejectedBy")
  overtimeApprovalHistories OvertimeApprovalHistory[]  @relation("OvertimeActionBy")

  createdAt DateTime @default(dbgenerated("sysutcdatetime()"))
  updatedAt DateTime @default(dbgenerated("sysutcdatetime()")) @updatedAt

  @@index([roleId], name: "IX_ErpTSUser_roleId")
  @@index([departmentId], name: "IX_ErpTSUser_departmentId")
  @@map("ErpTSUser")
}

// ---------------------------------------------------------
// PROJECTS & TASKS
// ---------------------------------------------------------
model Project {
  id           String   @id @default(dbgenerated("newid()")) @db.UniqueIdentifier
  projectNo    String?  @unique
  name         String   @db.NVarChar(200)
  category     String   @default("Project") @db.NVarChar(100)
  businessUnit String?  @db.NVarChar(255)
  description  String?  @db.NVarChar(Max)
  status       String   @default("ACTIVE") @db.NVarChar(50)
  salesPerson    String?  @db.NVarChar(255)
  technicalHead  String?  @db.NVarChar(255)
  teamLead       String?  @db.NVarChar(255)
  subTeamLead    String?  @db.NVarChar(255)
  designers      String?  @db.NVarChar(Max)
  createdById    String?  @db.UniqueIdentifier
  createdBy    User?    @relation("ProjectCreator", fields: [createdById], references: [id], onDelete: NoAction, onUpdate: NoAction)
  tasks        Task[]
  signRows     ProjectSignRow[]
  chatterPosts ChatterPost[]
  attachments  ProjectAttachment[]
  qsStatus     ProjectQsStatus?
  qsAssignments ProjectQsAssignment[]
  createdAt    DateTime @default(dbgenerated("sysutcdatetime()"))
  updatedAt    DateTime @default(dbgenerated("sysutcdatetime()")) @updatedAt

  @@index([createdById])
  @@map("ErpTSProject")
}

model ProjectQsAssignment {
  id         String   @id @default(dbgenerated("newid()")) @db.UniqueIdentifier
  projectId  String   @db.UniqueIdentifier
  project    Project  @relation(fields: [projectId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  qsUserId   String   @db.UniqueIdentifier
  qsUser     User     @relation("ProjectQsAssignments", fields: [qsUserId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  assignedAt DateTime @default(dbgenerated("sysutcdatetime()"))

  @@unique([projectId, qsUserId], name: "UQ_ErpTSProjectQsAssignment_project_user")
  @@index([qsUserId, assignedAt(sort: Desc)], name: "IX_ErpTSProjectQsAssignment_qsUserId")
  @@map("ErpTSProjectQsAssignment")
}

model ProjectQsStatus {
  projectId     String    @id @db.UniqueIdentifier
  project       Project   @relation(fields: [projectId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  status        String    @default("Pending") @db.NVarChar(20)
  updatedById   String?   @db.UniqueIdentifier
  updatedBy     User?     @relation("ProjectQsStatusUpdatedBy", fields: [updatedById], references: [id], onDelete: NoAction, onUpdate: NoAction)
  submittedById String?   @db.UniqueIdentifier
  submittedBy   User?     @relation("ProjectQsStatusSubmittedBy", fields: [submittedById], references: [id], onDelete: NoAction, onUpdate: NoAction)
  submittedAt   DateTime? @db.DateTime2
  createdAt     DateTime  @default(dbgenerated("sysutcdatetime()"))
  updatedAt     DateTime  @default(dbgenerated("sysutcdatetime()")) @updatedAt

  @@map("ErpTSProjectQsStatus")
}

model Task {
  id          String    @id @default(dbgenerated("newid()")) @db.UniqueIdentifier
  taskNo      String    @unique @db.NVarChar(100)
  opNo        String?   @db.NVarChar(100)
  title       String?   @db.NVarChar(200)
  revisionCode String?  @db.NVarChar(20)
  designType   String?  @db.NVarChar(80)
  signType       String?  @db.NVarChar(255)
  signFamily     String?  @db.NVarChar(255)
  disciplineType String?  @db.NVarChar(50)
  description String?   @db.NVarChar(Max)
  status      String    @default("DESIGN_NEW") @db.NVarChar(20)
  priority    String    @default("Medium") @db.NVarChar(50)
  projectId   String    @db.UniqueIdentifier
  assigneeId  String?   @db.UniqueIdentifier
  dueDate     DateTime?
  startedAt          DateTime?
  completedAt        DateTime?
  holdPreviousStatus String?   @db.NVarChar(50)

  // Rework context — populated on the NEW revision task when rework is issued
  reworkNote             String?  @db.NVarChar(Max)
  reworkAttachmentUrl    String?  @db.NVarChar(500)
  reworkAttachmentName   String?  @db.NVarChar(255)
  reworkLinkUrl          String?  @db.NVarChar(500)
  reworkLinkName         String?  @db.NVarChar(255)
  previousRevisionTaskId String?  @db.NVarChar(36)

  technicalHead  String?  @db.NVarChar(255)
  teamLead       String?  @db.NVarChar(255)
  subTeamLead    String?  @db.NVarChar(255)
  designers      String?  @db.NVarChar(Max)

  project                Project                 @relation(fields: [projectId], references: [id], onUpdate: NoAction)
  assignee               User?                   @relation("TaskAssignee", fields: [assigneeId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  chatterPosts           ChatterPost[]
  activityLogs           ActivityLog[]
  regularizationRequests RegularizationRequest[]
  overtimeRequests       OvertimeRequest[]
  schedulerAssignments   SchedulerAssignment[]
  schedulerFragments     SchedulerTaskFragment[]
  retailDetails          RetailTaskDetail[]
  projectDetails         ProjectTaskDetail[]
  workSessions           TaskWorkSession[]
  taskDesigners          TaskDesigner[]         @relation("TaskDesigners")

  createdAt DateTime @default(dbgenerated("sysutcdatetime()"))
  updatedAt DateTime @default(dbgenerated("sysutcdatetime()")) @updatedAt

  @@index([projectId])
  @@index([assigneeId])
  @@index([projectId, opNo, designType, revisionCode, signType, disciplineType])
  @@map("ErpTSTask")
}

model RetailTaskDetail {
  id             String   @id @default(dbgenerated("newid()")) @db.UniqueIdentifier
  taskId         String   @db.UniqueIdentifier
  task           Task     @relation(fields: [taskId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  attachments    RetailTaskDetailAttachment[]
  providedFile   String?  @db.NVarChar(255)
  fileKey        String?  @db.NVarChar(1024)
  fileUrl        String?  @db.NVarChar(2000)
  hodName        String?  @db.NVarChar(255)
  designTypes    String?  @db.NVarChar(500)
  hoursRequired  Int?
  comment        String?  @db.NVarChar(Max)
  signFamily     String?  @db.NVarChar(255)
  signType       String?  @db.NVarChar(255)
  planCode       String?  @db.NVarChar(100)
  contractRef    String?  @db.NVarChar(100)
  quantity       Int?
  deadline       DateTime?
  createdAt      DateTime @default(now())

  @@index([taskId])
  @@map("ErpTSRetailTaskDetail")
}

model ProjectTaskDetail {
  id             String   @id @default(dbgenerated("newid()")) @db.UniqueIdentifier
  taskId         String   @db.UniqueIdentifier
  task           Task     @relation(fields: [taskId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  attachments    ProjectTaskDetailAttachment[]
  signType       String?  @db.NVarChar(255)
  planCode       String?  @db.NVarChar(100)
  area           String?  @db.NVarChar(100)
  level          String?  @db.NVarChar(100)
  artwork        Boolean? @default(false)
  artworkHours   Int?
  technical      Boolean? @default(false)
  technicalHours Int?
  location       Boolean? @default(false)
  locationHours  Int?
  asBuilt        Boolean? @default(false)
  asBuiltHours   Int?
  bim            Boolean? @default(false)
  deadline       DateTime?
  comment        String?  @db.NVarChar(Max)
  createdAt      DateTime @default(now())

  @@index([taskId])
  @@map("ErpTSProjectTaskDetail")
}

model ProjectSignRow {
  id          String   @id @default(dbgenerated("newid()")) @db.UniqueIdentifier
  projectId   String   @db.UniqueIdentifier
  project     Project  @relation(fields: [projectId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  tNo         String?  @db.NVarChar(50)
  no          String?  @db.NVarChar(50)
  signType    String?  @db.NVarChar(255)
  planCode    String?  @db.NVarChar(100)
  estQty      Int?
  qsQty       Int?
  areaZone    String?  @db.NVarChar(100)
  levelParcel String?  @db.NVarChar(100)
  sequence    String?  @db.NVarChar(100)
  status      String?  @db.NVarChar(50)
  comment     String?  @db.NVarChar(Max)
  contRef     String?  @db.NVarChar(100)
  signFamily  String?  @db.NVarChar(255)
  createdAt   DateTime @default(now())

  @@index([projectId])
  @@map("ErpTSProjectSignRow")
}

model ProjectAttachment {
  id           String   @id @default(dbgenerated("newid()")) @db.UniqueIdentifier
  projectId    String   @db.UniqueIdentifier
  project      Project  @relation(fields: [projectId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  fileKey      String   @db.NVarChar(1024)
  fileName     String   @db.NVarChar(255)
  mimeType     String?  @db.NVarChar(100)
  sizeBytes    BigInt?
  uploadedById String?  @db.UniqueIdentifier
  uploadedBy   User?    @relation(fields: [uploadedById], references: [id], onDelete: NoAction, onUpdate: NoAction)
  createdAt    DateTime @default(now())

  @@index([projectId])
  @@index([createdAt])
  @@map("ErpTSProjectAttachment")
}

model RetailTaskDetailAttachment {
  id                 String           @id @default(dbgenerated("newid()")) @db.UniqueIdentifier
  retailTaskDetailId String           @db.UniqueIdentifier
  retailTaskDetail   RetailTaskDetail @relation(fields: [retailTaskDetailId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  fileKey            String           @db.NVarChar(1024)
  fileName           String           @db.NVarChar(255)
  mimeType           String?          @db.NVarChar(100)
  sizeBytes          BigInt?
  createdAt          DateTime         @default(now())

  @@index([retailTaskDetailId])
  @@index([createdAt])
  @@map("ErpTSRetailTaskDetailAttachment")
}

model ProjectTaskDetailAttachment {
  id                  String            @id @default(dbgenerated("newid()")) @db.UniqueIdentifier
  projectTaskDetailId String            @db.UniqueIdentifier
  projectTaskDetail   ProjectTaskDetail @relation(fields: [projectTaskDetailId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  fileKey             String            @db.NVarChar(1024)
  fileName            String            @db.NVarChar(255)
  mimeType            String?           @db.NVarChar(100)
  sizeBytes           BigInt?
  createdAt           DateTime          @default(now())

  @@index([projectTaskDetailId])
  @@index([createdAt])
  @@map("ErpTSProjectTaskDetailAttachment")
}

// ---------------------------------------------------------
// DESIGN LIST (ERP design tasks — separate from ErpTSTask)
// ---------------------------------------------------------
model DesignTask {
  id                 String    @id @default(dbgenerated("newid()")) @db.UniqueIdentifier
  opNo               String?   @db.NVarChar(100)
  projectNo          String?   @db.NVarChar(100)
  name               String?   @db.NVarChar(255)
  description        String?   @db.NVarChar(Max)
  designType         String?   @db.NVarChar(50)
  businessUnit       String?   @db.NVarChar(100)
  status             String?   @db.NVarChar(50)
  salesPerson        String?   @db.UniqueIdentifier
  assignedDesignerId String?   @db.UniqueIdentifier
  assignedDesigner   User?     @relation("DesignTaskAssignee", fields: [assignedDesignerId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  lastUpdatedBy      String?   @db.UniqueIdentifier
  updatedBy          User?     @relation("DesignTaskUpdatedBy", fields: [lastUpdatedBy], references: [id], onDelete: NoAction, onUpdate: NoAction)
  deadline           DateTime? @db.DateTime
  agingDays          Int?
  priority           String?   @db.NVarChar(20)
  estimatedHours     Decimal?  @db.Decimal(10, 2)
  completedHours     Decimal?  @db.Decimal(10, 2)
  revisionCount      Int?      @default(0)
  completionPercentage Int?    @default(0)
  isOverdue          Boolean?  @default(false)
  isDeleted          Boolean?  @default(false)
  created            DateTime? @default(now()) @db.DateTime
  createdAt          DateTime? @default(now()) @db.DateTime
  updatedAt          DateTime? @default(now()) @updatedAt @db.DateTime
  signageDetails     SignageDetail[]

  @@map("ErpTSDesignTask")
}

model SignageDetail {
  id          String     @id @default(dbgenerated("newid()")) @db.UniqueIdentifier
  taskId      String?    @db.UniqueIdentifier
  designTask  DesignTask? @relation(fields: [taskId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  signFamily  String?    @db.NVarChar(255)
  signType    String?    @db.NVarChar(255)
  planCode    String?    @db.NVarChar(100)
  contractRef String?    @db.NVarChar(100)
  quantity    Int?
  createdAt   DateTime?  @default(now()) @db.DateTime

  @@map("ErpTSSignageDetail")
}

// ---------------------------------------------------------
// CHATTER & ATTACHMENTS
// ---------------------------------------------------------
model ChatterPost {
  id              String    @id @default(dbgenerated("newid()")) @db.UniqueIdentifier
  title           String?   @db.NVarChar(255)
  message         String?   @db.NVarChar(Max)
  postType        String?   @db.NVarChar(50)
  priority        String?   @db.NVarChar(20)
  visibility      String?   @db.NVarChar(50)
  seenByCount     Int?      @default(0)
  attachmentCount Int?      @default(0)
  isPinned        Boolean?  @default(false)
  editedAt        DateTime? @db.DateTime

  taskId        String? @db.UniqueIdentifier
  task          Task?   @relation(fields: [taskId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  projectId     String? @db.UniqueIdentifier
  project       Project? @relation(fields: [projectId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  authorId      String? @db.UniqueIdentifier
  author        User?   @relation("PostAuthor", fields: [authorId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  mentionUserId String? @db.UniqueIdentifier
  mentionUser   User?   @relation("MentionedUser", fields: [mentionUserId], references: [id], onDelete: NoAction, onUpdate: NoAction)

  attachments     Attachment[]
  links           LinkAttachment[]
  comments        ChatterComment[]
  mentionEntries  ChatterPostMention[]
  likes           ChatterPostLike[]
  seenBy          ChatterPostSeen[]

  createdAt DateTime? @default(now()) @db.DateTime
  updatedAt DateTime? @default(now()) @updatedAt @db.DateTime

  @@index([taskId], name: "IX_ErpTSChatterPost_taskId")
  @@index([projectId], name: "IX_ErpTSChatterPost_projectId")
  @@index([authorId], name: "IX_ErpTSChatterPost_authorId")
  @@index([createdAt(sort: Desc)], name: "IX_ErpTSChatterPost_createdAt")
  @@map("ErpTSChatterPost")
}

model ChatterComment {
  id       String    @id @default(dbgenerated("newid()")) @db.UniqueIdentifier
  postId   String?   @db.UniqueIdentifier
  post     ChatterPost? @relation(fields: [postId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  authorId String?   @db.UniqueIdentifier
  author   User?     @relation("CommentAuthor", fields: [authorId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  mentionUserId String? @db.UniqueIdentifier
  mentionUser   User? @relation("CommentMentionedUser", fields: [mentionUserId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  message  String?   @db.NVarChar(Max)
  createdAt DateTime? @default(now()) @db.DateTime

  mentionEntries ChatterCommentMention[]

  @@index([postId], name: "IX_ErpTSChatterComment_postId")
  @@map("ErpTSChatterComment")
}

model ChatterPostMention {
  id        String      @id @default(dbgenerated("newid()")) @db.UniqueIdentifier
  postId    String      @db.UniqueIdentifier
  post      ChatterPost @relation(fields: [postId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  userId    String      @db.UniqueIdentifier
  user      User        @relation("ChatterPostMentions", fields: [userId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  createdAt DateTime    @default(dbgenerated("sysutcdatetime()")) @db.DateTime

  @@unique([postId, userId], name: "UQ_ErpTSChatterPostMention_post_user")
  @@index([userId], name: "IX_ErpTSChatterPostMention_userId")
  @@map("ErpTSChatterPostMention")
}

model ChatterCommentMention {
  id        String         @id @default(dbgenerated("newid()")) @db.UniqueIdentifier
  commentId String         @db.UniqueIdentifier
  comment   ChatterComment @relation(fields: [commentId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  userId    String         @db.UniqueIdentifier
  user      User           @relation("ChatterCommentMentions", fields: [userId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  createdAt DateTime       @default(dbgenerated("sysutcdatetime()")) @db.DateTime

  @@unique([commentId, userId], name: "UQ_ErpTSChatterCommentMention_comment_user")
  @@index([userId], name: "IX_ErpTSChatterCommentMention_userId")
  @@map("ErpTSChatterCommentMention")
}

model ChatterPostLike {
  id        String      @id @default(dbgenerated("newid()")) @db.UniqueIdentifier
  postId    String      @db.UniqueIdentifier
  post      ChatterPost @relation(fields: [postId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  userId    String      @db.UniqueIdentifier
  user      User        @relation("ChatterPostLikes", fields: [userId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  createdAt DateTime    @default(dbgenerated("sysutcdatetime()")) @db.DateTime

  @@unique([postId, userId], name: "UQ_ErpTSChatterPostLike_post_user")
  @@map("ErpTSChatterPostLike")
}

model ChatterPostSeen {
  id        String      @id @default(dbgenerated("newid()")) @db.UniqueIdentifier
  postId    String      @db.UniqueIdentifier
  post      ChatterPost @relation(fields: [postId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  userId    String      @db.UniqueIdentifier
  user      User        @relation("ChatterPostSeen", fields: [userId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  seenAt    DateTime    @default(dbgenerated("sysutcdatetime()")) @db.DateTime

  @@unique([postId, userId], name: "UQ_ErpTSChatterPostSeen_post_user")
  @@index([userId], name: "IX_ErpTSChatterPostSeen_userId")
  @@index([postId], name: "IX_ErpTSChatterPostSeen_postId")
  @@map("ErpTSChatterPostSeen")
}

model Attachment {
  id            String      @id @default(dbgenerated("newid()")) @db.UniqueIdentifier
  fileName      String      @db.NVarChar(255)
  filePath      String
  fileUrl       String?     @db.NVarChar(2000)
  mimeType      String?     @db.NVarChar(100)
  sizeBytes     BigInt?
  chatterPostId String      @db.UniqueIdentifier
  chatterPost   ChatterPost @relation(fields: [chatterPostId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  createdAt     DateTime?   @default(now()) @db.DateTime

  @@map("ErpTSChatterPostAttachment")
}

model LinkAttachment {
  id            String      @id @default(dbgenerated("newid()")) @db.UniqueIdentifier
  url           String      @db.NVarChar(2000)
  platform      String?     @db.NVarChar(255)
  displayName   String?
  chatterPostId String      @db.UniqueIdentifier
  chatterPost   ChatterPost @relation(fields: [chatterPostId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  createdAt     DateTime    @default(now())

  @@map("ErpTSLinkAttachment")
}

// ---------------------------------------------------------
// REQUESTS (leave, regularization, overtime)
// ---------------------------------------------------------
model LeaveRequest {
  id              String    @id @default(dbgenerated("newid()")) @db.UniqueIdentifier
  userId          String    @db.UniqueIdentifier
  user            User      @relation(fields: [userId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  type            String    @db.NVarChar(255)
  status          String    @default("Pending") @db.NVarChar(255)
  startDate       DateTime
  endDate         DateTime?
  halfDaySession  String?   @db.NVarChar(50)
  reason          String?   @db.NVarChar(Max)
  approverId      String?   @db.UniqueIdentifier
  approver        User?     @relation("LeaveApprover", fields: [approverId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  approverRemarks String?   @db.NVarChar(Max)
  reviewedAt      DateTime? @db.DateTime
  revokedById     String?   @db.UniqueIdentifier
  revokedBy       User?     @relation("LeaveRevoker", fields: [revokedById], references: [id], onDelete: NoAction, onUpdate: NoAction)
  revokedAt       DateTime? @db.DateTime
  revocationReason String? @db.NVarChar(Max)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @default(now()) @updatedAt

  @@index([userId, status], name: "IX_ErpTSLeaveRequest_userId_status")
  @@map("ErpTSLeaveRequest")
}

model RegularizationRequest {
  id         String    @id @default(dbgenerated("newid()")) @db.UniqueIdentifier
  designerId String?   @db.UniqueIdentifier
  designer   User?     @relation("RegularizationDesigner", fields: [designerId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  taskId     String?   @db.UniqueIdentifier
  task       Task?     @relation(fields: [taskId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  date       DateTime? @db.Date
  duration   String?   @db.NVarChar(100)
  reason     String?   @db.NVarChar(100)
  notes      String?   @db.NVarChar(Max)
  status     String?   @db.NVarChar(50)
  approverId String?   @db.UniqueIdentifier
  approver   User?     @relation("RegularizationApprover", fields: [approverId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  approverRemarks String? @db.NVarChar(Max)
  reviewedAt DateTime? @db.DateTime
  createdAt  DateTime? @default(now())

  @@index([designerId, status], name: "IX_ErpTSRegularizationRequest_designerId_status")
  @@map("ErpTSRegularizationRequest")
}

model OvertimeRequest {
  id                 String    @id @default(dbgenerated("newid()")) @db.UniqueIdentifier
  designerId         String?   @db.UniqueIdentifier
  designer           User?     @relation("OvertimeDesigner", fields: [designerId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  taskId             String?   @db.UniqueIdentifier
  task               Task?     @relation(fields: [taskId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  date               DateTime? @db.Date
  estimatedRemaining String?   @db.NVarChar(255)
  requestedHours     Decimal?  @db.Decimal(10, 2)
  approvedHours      Decimal?  @db.Decimal(10, 2)
  reason             String?   @db.NVarChar(Max)
  status             String?   @db.NVarChar(50)
  createdAt          DateTime? @default(now())

  startTime          String?   @db.NVarChar(50)
  endTime            String?   @db.NVarChar(50)
  totalHours         Decimal?  @db.Decimal(10, 2)
  managerComments    String?   @db.NVarChar(Max)
  hrComments         String?   @db.NVarChar(Max)
  approvedById       String?   @db.UniqueIdentifier
  approvedBy         User?     @relation("OvertimeApprovedBy", fields: [approvedById], references: [id], onDelete: NoAction, onUpdate: NoAction)
  approvedAt         DateTime? @db.DateTime
  rejectedById       String?   @db.UniqueIdentifier
  rejectedBy         User?     @relation("OvertimeRejectedBy", fields: [rejectedById], references: [id], onDelete: NoAction, onUpdate: NoAction)
  rejectedAt         DateTime? @db.DateTime
  updatedAt          DateTime? @default(dbgenerated("sysutcdatetime()")) @updatedAt

  history            OvertimeApprovalHistory[]
  attachments        OvertimeAttachment[]

  @@index([designerId, status], name: "IX_ErpTSOvertimeRequest_designerId_status")
  @@index([date], name: "IX_ErpTSOvertimeRequest_date")
  @@map("ErpTSOvertimeRequest")
}

model OvertimeApprovalHistory {
  id         String          @id @default(dbgenerated("newid()")) @db.UniqueIdentifier
  requestId  String          @db.UniqueIdentifier
  request    OvertimeRequest @relation(fields: [requestId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  action     String          @db.NVarChar(100)
  actionById String          @db.UniqueIdentifier
  actionBy   User            @relation("OvertimeActionBy", fields: [actionById], references: [id], onDelete: NoAction, onUpdate: NoAction)
  comments   String?         @db.NVarChar(Max)
  createdAt  DateTime        @default(now())

  @@index([requestId], name: "IX_ErpTSOvertimeApprovalHistory_requestId")
  @@map("ErpTSOvertimeApprovalHistory")
}

model OvertimeAttachment {
  id                String          @id @default(dbgenerated("newid()")) @db.UniqueIdentifier
  fileName          String          @db.NVarChar(255)
  filePath          String          @db.NVarChar(Max)
  mimeType          String?         @db.NVarChar(100)
  sizeBytes         BigInt?
  overtimeRequestId String          @db.UniqueIdentifier
  overtimeRequest   OvertimeRequest @relation(fields: [overtimeRequestId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  createdAt         DateTime        @default(now())

  @@map("ErpTSOvertimeAttachment")
}

// ---------------------------------------------------------
// SCHEDULER
// ---------------------------------------------------------
model SchedulerAssignment {
  id            String    @id @default(dbgenerated("newid()")) @db.UniqueIdentifier
  designerId    String?   @db.UniqueIdentifier
  designer      User?     @relation("SchedulerDesigner", fields: [designerId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  taskId        String?   @db.UniqueIdentifier
  task          Task?     @relation(fields: [taskId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  dayIndex      Int?
  assignedHours Decimal?  @db.Decimal(10, 2)
  parentId      String?   @db.UniqueIdentifier
  splitIndex    Int?
  totalParts    Int?
  weekStartDate DateTime? @db.Date
  weekEndDate   DateTime? @db.Date
  notes         String?   @db.NVarChar(Max)
  position      Int?      @default(0)
  isLocked      Boolean?  @default(false)
  isPinned      Boolean?  @default(false)
  assignedBy    String?   @db.UniqueIdentifier
  assignedByUser User?    @relation("SchedulerAssignedBy", fields: [assignedBy], references: [id], onDelete: NoAction, onUpdate: NoAction)
  createdAt     DateTime? @default(now())
  updatedAt     DateTime? @default(now()) @updatedAt

  @@index([weekStartDate, designerId], name: "IX_ErpTSSchedulerAssignment_week_designer")
  @@index([weekStartDate, taskId], name: "IX_ErpTSSchedulerAssignment_week_task")
  @@map("ErpTSSchedulerAssignment")
}

// A single split part detached from its siblings via a per-part unassign/hold action
// (see SCHEDULER_RULES.md Rule 5a). Siblings that are still actively scheduled are
// untouched; this row is the detached part's own record so it can show as its own
// sidebar card and be re-dropped onto the grid later without disturbing the rest.
model SchedulerTaskFragment {
  id               String   @id @default(dbgenerated("newid()")) @db.UniqueIdentifier
  taskId           String   @db.UniqueIdentifier
  task             Task     @relation(fields: [taskId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  parentId         String?  @db.UniqueIdentifier
  hours            Decimal  @db.Decimal(10, 2)
  status           String   @db.NVarChar(20)
  sourceDesignerId String?  @db.UniqueIdentifier
  splitIndex       Int?
  totalParts       Int?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @default(now()) @updatedAt

  @@index([taskId])
  @@map("ErpTSSchedulerTaskFragment")
}

model SchedulerWeek {
  id              String   @id @default(dbgenerated("newid()")) @db.UniqueIdentifier
  weekStartDate   DateTime @unique @db.Date
  version         Int      @default(0)
  isLocked        Boolean  @default(false)
  updatedBy       String?  @db.UniqueIdentifier
  updatedByUser   User?    @relation("SchedulerWeekUpdatedBy", fields: [updatedBy], references: [id], onDelete: NoAction, onUpdate: NoAction)
  lastPayloadHash String?  @db.NVarChar(128)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @default(now()) @updatedAt

  @@map("ErpTSSchedulerWeek")
}

model SchedulerAssignmentHistory {
  id            String   @id @default(dbgenerated("newid()")) @db.UniqueIdentifier
  weekStartDate DateTime @db.Date
  versionFrom   Int
  versionTo     Int
  changedBy     String?  @db.UniqueIdentifier
  changedByUser User?    @relation("SchedulerAssignmentHistoryChangedBy", fields: [changedBy], references: [id], onDelete: NoAction, onUpdate: NoAction)
  beforeJson    String?  @db.NVarChar(Max)
  afterJson     String?  @db.NVarChar(Max)
  createdAt     DateTime @default(now())

  @@index([weekStartDate])
  @@map("ErpTSSchedulerAssignmentHistory")
}

model Holiday {
  id        String   @id @default(dbgenerated("newid()")) @db.UniqueIdentifier
  date      DateTime @unique @db.Date
  name      String?  @db.NVarChar(255)
  createdAt DateTime @default(dbgenerated("sysutcdatetime()"))
  updatedAt DateTime @default(dbgenerated("sysutcdatetime()")) @updatedAt

  @@map("ErpTSHoliday")
}

model LeaveRescheduleSnapshot {
  id             String    @id @default(dbgenerated("newid()")) @db.UniqueIdentifier
  leaveRequestId String    @db.UniqueIdentifier
  assignmentId   String    @db.UniqueIdentifier
  originalJson   String    @db.NVarChar(Max)
  createdAt      DateTime  @default(dbgenerated("sysutcdatetime()"))
  restoredAt     DateTime? @db.DateTime2

  @@unique([leaveRequestId, assignmentId], name: "UX_ErpTSLeaveRescheduleSnapshot_leave_assignment")
  @@map("ErpTSLeaveRescheduleSnapshot")
}

// ---------------------------------------------------------
// ACTIVITY & NOTIFICATIONS
// ---------------------------------------------------------
model ActivityLog {
  id        String   @id @default(dbgenerated("newid()")) @db.UniqueIdentifier
  action    String   @db.NVarChar(1000)
  details   String?  @db.NVarChar(Max)
  userId    String   @db.UniqueIdentifier
  user      User     @relation(fields: [userId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  taskId    String?  @db.UniqueIdentifier
  task      Task?    @relation(fields: [taskId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  createdAt DateTime @default(now())

  @@index([userId], name: "IX_ErpTSActivityLog_userId")
  @@index([taskId], name: "IX_ErpTSActivityLog_taskId")
  @@index([createdAt(sort: Desc)], name: "IX_ErpTSActivityLog_createdAt")
  @@map("ErpTSActivityLog")
}

model Notification {
  id        String   @id @default(dbgenerated("newid()")) @db.UniqueIdentifier
  userId    String   @db.UniqueIdentifier
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  title     String
  message   String   @db.NVarChar(Max)
  isRead    Boolean  @default(false)
  linkUrl   String?  @db.NVarChar(2000)
  createdAt DateTime @default(now())

  @@index([userId, createdAt(sort: Desc)])
  @@map("ErpTSNotification")
}

model InboxReadMarker {
  id        String   @id @default(dbgenerated("newid()")) @db.UniqueIdentifier
  userId    String   @db.UniqueIdentifier
  user      User     @relation("InboxReadMarkers", fields: [userId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  itemKey   String   @db.NVarChar(200)
  isRead    Boolean  @default(true)
  updatedAt DateTime @updatedAt

  @@unique([userId, itemKey])
  @@index([userId])
  @@map("ErpTSInboxRead")
}

// ---------------------------------------------------------
// REALTIME CHAT / CONVERSATIONS (CHATTER DIRECT MESSAGES)
// ---------------------------------------------------------
model Conversation {
  id        String   @id @default(dbgenerated("newid()")) @db.UniqueIdentifier
  name      String?  @db.NVarChar(255)
  isGroup   Boolean  @default(false)
  createdAt DateTime @default(dbgenerated("sysutcdatetime()"))
  updatedAt DateTime @default(dbgenerated("sysutcdatetime()")) @updatedAt

  participants ConversationParticipant[]
  messages     Message[]

  @@map("ErpTSConversation")
}

model ConversationParticipant {
  id             String       @id @default(dbgenerated("newid()")) @db.UniqueIdentifier
  conversationId String       @db.UniqueIdentifier
  userId         String       @db.UniqueIdentifier
  joinedAt       DateTime     @default(dbgenerated("sysutcdatetime()"))
  lastReadAt     DateTime     @default(dbgenerated("sysutcdatetime()"))

  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@unique([conversationId, userId])
  @@map("ErpTSConversationParticipant")
}

model Message {
  id             String       @id @default(dbgenerated("newid()")) @db.UniqueIdentifier
  conversationId String       @db.UniqueIdentifier
  senderId       String       @db.UniqueIdentifier
  content        String       @db.NVarChar(Max)
  createdAt      DateTime     @default(dbgenerated("sysutcdatetime()"))
  updatedAt      DateTime     @default(dbgenerated("sysutcdatetime()")) @updatedAt

  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  sender         User         @relation("MessageSender", fields: [senderId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([conversationId, createdAt(sort: Desc)], name: "IX_ErpTSMessage_conversationId_createdAt")
  @@map("ErpTSMessage")
}

// ---------------------------------------------------------
// TASK WORK SESSIONS (timer submissions)
// ---------------------------------------------------------
model TaskWorkSession {
  id              String   @id @default(dbgenerated("newid()")) @db.UniqueIdentifier
  taskId          String   @db.UniqueIdentifier
  task            Task     @relation(fields: [taskId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  designerId      String   @db.UniqueIdentifier
  designer        User     @relation("WorkSessionDesigner", fields: [designerId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  durationSeconds Int
  submissionLink  String?  @db.NVarChar(2000)
  pauseLog        String?  @db.NVarChar(Max)
  status          String   @default("Submitted") @db.NVarChar(50)
  submittedAt     DateTime @default(now())
  createdAt       DateTime @default(now())
  files           TaskWorkSessionFile[]

  @@index([taskId])
  @@index([designerId])
  @@map("ErpTSTaskWorkSession")
}

model TaskWorkSessionFile {
  id        String          @id @default(dbgenerated("newid()")) @db.UniqueIdentifier
  sessionId String          @db.UniqueIdentifier
  session   TaskWorkSession @relation(fields: [sessionId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  fileKey   String          @db.NVarChar(1024)
  fileName  String          @db.NVarChar(255)
  mimeType  String?         @db.NVarChar(100)
  sizeBytes BigInt?
  createdAt DateTime        @default(now())

  @@index([sessionId])
  @@map("ErpTSTaskWorkSessionFile")
}

// ---------------------------------------------------------
// TASK DESIGNER JUNCTION (split task multi-designer support)
// ---------------------------------------------------------
model TaskDesigner {
  id         String @id @default(dbgenerated("newid()")) @db.UniqueIdentifier
  taskId     String @db.UniqueIdentifier
  designerId String @db.UniqueIdentifier

  task       Task   @relation("TaskDesigners", fields: [taskId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  designer   User   @relation("TaskDesignerUsers", fields: [designerId], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@unique([taskId, designerId])
  @@index([taskId])
  @@index([designerId])
  @@map("ErpTSTaskDesigner")
}
