generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlserver"
  url      = env("DATABASE_URL")
}

// ---------------------------------------------------------
// USERS & ROLES
// ---------------------------------------------------------
model Role {
  id          String   @id @default(uuid())
  name        String   @unique
  permissions String?
  users       User[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Department {
  id        String   @id @default(uuid())
  name      String   @unique
  users     User[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model User {
  id           String      @id @default(uuid())
  email        String      @unique
  passwordHash String
  fullName     String
  roleId       String
  role         Role        @relation(fields: [roleId], references: [id])
  departmentId String?
  department   Department? @relation(fields: [departmentId], references: [id])
  tasks        Task[]        @relation("TaskAssignee")
  projects     Project[]     @relation("ProjectCreator")
  chatterPosts ChatterPost[] @relation("PostAuthor")
  activities   ActivityLog[]
  leaveRequests LeaveRequest[]
  notifications Notification[]
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
}

// ---------------------------------------------------------
// PROJECTS
// ---------------------------------------------------------
model Project {
  id           String   @id @default(uuid())
  projectNo    String?  @unique
  name         String
  category     String   @default("Project") // "Retail" | "Project"
  businessUnit String?
  description  String?
  status       String   @default("ACTIVE")  // ACTIVE | COMPLETED | ON_HOLD
  salesPerson  String?
  createdById  String?
  tasks        Task[]
  createdBy    User?    @relation("ProjectCreator", fields: [createdById], references: [id], onDelete: NoAction, onUpdate: NoAction)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([createdById])
}

// ---------------------------------------------------------
// TASKS
// ---------------------------------------------------------
model Task {
  id          String    @id @default(uuid())
  opNo        String?   @unique
  title       String
  description String?
  status      String    @default("PENDING")  // PENDING | WIP | COMPLETED | REVISION | APPROVED
  priority    String    @default("Medium")   // High | Medium | Low
  projectId   String
  project     Project   @relation(fields: [projectId], references: [id])
  assigneeId  String?
  assignee    User?     @relation("TaskAssignee", fields: [assigneeId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  dueDate      DateTime?
  startedAt    DateTime?
  completedAt  DateTime?
  chatterPosts ChatterPost[]
  activityLogs ActivityLog[]
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  @@index([projectId])
  @@index([assigneeId])
}

// ---------------------------------------------------------
// CHATTER & ATTACHMENTS
// ---------------------------------------------------------
model ChatterPost {
  id              String           @id @default(uuid())
  title           String
  message         String
  postType        String?          // e.g., "General", "Update", "Issue"
  priority        String?
  visibility      String?
  seenByCount     Int              @default(0)
  isPinned        Boolean          @default(false)
  
  taskId          String?
  task            Task?            @relation(fields: [taskId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  
  authorId        String
  author          User             @relation("PostAuthor", fields: [authorId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  mentionUserId   String?          // Can be linked to User table later
  
  attachments     Attachment[]
  links           LinkAttachment[]
  
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
}

model Attachment {
  id              String       @id @default(uuid())
  fileName        String
  filePath        String
  mimeType        String?
  sizeBytes       Int?
  
  chatterPostId   String?
  chatterPost     ChatterPost? @relation(fields: [chatterPostId], references: [id], onDelete: Cascade)
  
  uploadedById    String?
  createdAt       DateTime     @default(now())
}

model LinkAttachment {
  id              String      @id @default(uuid())
  url             String
  platform        String?     // e.g., "OneDrive", "Google Drive"
  displayName     String?
  
  chatterPostId   String
  chatterPost     ChatterPost @relation(fields: [chatterPostId], references: [id], onDelete: Cascade)
  
  createdAt       DateTime    @default(now())
}

// ---------------------------------------------------------
// TEAM ACTIVITY & LOGS
// ---------------------------------------------------------
model ActivityLog {
  id              String   @id @default(uuid())
  action          String   // e.g., "CREATED_TASK", "STATUS_CHANGED"
  details         String?  // JSON string for old/new values
  
  userId          String
  user            User     @relation(fields: [userId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  
  taskId          String?
  task            Task?    @relation(fields: [taskId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  
  createdAt       DateTime @default(now())
}

// ---------------------------------------------------------
// LEAVE & REGULARIZATION REQUESTS
// ---------------------------------------------------------
model LeaveRequest {
  id              String   @id @default(uuid())
  userId          String
  user            User     @relation(fields: [userId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  type            String   // "Leave", "Half Day", "Regularization"
  status          String   @default("Pending") // Approved, Rejected, Pending
  startDate       DateTime
  endDate         DateTime?
  reason          String?
  
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

// ---------------------------------------------------------
// NOTIFICATIONS
// ---------------------------------------------------------
model Notification {
  id              String   @id @default(uuid())
  userId          String
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  title           String
  message         String
  isRead          Boolean  @default(false)
  linkUrl         String?
  
  createdAt       DateTime @default(now())
}
